rules_version = '2';
service cloud.firestore { match /databases/{database}/documents { function signedIn(){ return request.auth != null; } function isAdmin(){ return signedIn() && request.auth.token.permission.hasAny(['admin:access']); } match /users/{uid} { allow read: if signedIn() && (request.auth.uid == uid || isAdmin()); allow delete: if isAdmin(); allow create, update: if false; } match /refreshSessions/{id} { allow read, write: if false; } match /outboxMessages/{id} { allow read, write: if isAdmin(); } match /{document=**} { allow read, write: if isAdmin(); } } }
